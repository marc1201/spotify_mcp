# Non-secret configuration template. Copy to config.env and fill in your values:
#   cp config.env.example config.env   # then edit
# config.env is gitignored. Real secrets (client secret, JWT key, tunnel token) live in
# secrets.env.gpg (managed via scripts/set-secret.sh), never here and never committed.

# Spotify app Client ID (a public OAuth identifier, not a secret).
SPOTIFY_CLIENT_ID=your_spotify_client_id

# Public origin the connector is served at (your Cloudflare Tunnel hostname). https only.
BASE_URL=https://mcp.example.com

# Local port uvicorn binds (127.0.0.1 only; reached via the tunnel).
PORT=8080

# Space-separated Spotify user IDs allowed to use the connector. Empty = any authenticated user.
SPOTIFY_ALLOWED_USER_IDS=your_spotify_user_id

# GPG recipient (key id or email) that secrets.env.gpg is encrypted to, used by scripts/set-secret.sh.
SECRETS_RECIPIENT=you@example.com
